# CHAVE SECRETA JWT: Usada para assinar e validar tokens de autenticação
JWT_SECRET=sua_chave_secreta_super_segura_aqui

# PORTA DO SERVIDOR: Porta onde a aplicação será executada (Padrão: 3000)
PORT=3000

# CONFIGURAÇÃO DE E-MAIL (SMTP): Para envio real de e-mails em produção
# Use serviços como Resend, SendGrid, Mailgun ou seu próprio servidor SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TaskFlow <security@taskflow.com>"

# URL DA APLICAÇÃO: Usada para gerar links de recuperação (Ex: https://seu-app.run.app)
APP_URL=

# NOTA: Nunca compartilhe seu arquivo .env real com ninguém!
